  "asymmetries": [
    { "id": "substitution", "title": "The Substitution Asymmetry", "summary": "AI strongest in Zone A (moderate retirement pressure), weakest in Zone C (severe retirement pressure), creating an 8–12 million gap by 2030 that grows to 24–32 million by 2040." },
    { "id": "mobility", "title": "The Mobility Asymmetry", "summary": "Cross-zone retraining from cognitive to physical work is unprecedented, faces a 3% annual switching rate ceiling, and collapses in effectiveness for workers over 50 — the fastest-growing segment." },
    { "id": "immigration", "title": "The Immigration Asymmetry", "summary": "Immigrants fill Zone C shortages (67% construction, 50%+ food service, 30% care) but political tolerance is declining as AfD polls at 25%+, FPÖ wins 28.8%, and SVP pushes population caps." },
    { "id": "generational", "title": "The Generational Asymmetry", "summary": "Entry-level hiring collapses 73% for Gen Z while 40 million 55+ workers approach retirement, simultaneously depleting both ends of the talent pipeline." },
    { "id": "geographic", "title": "The Geographic Asymmetry", "summary": "AI displacement concentrates in office-heavy urban centres. Zone C shortages are distributed across hospitals, construction sites, care homes, and farms. Historical evidence shows displacement scarring lasts 30–50 years." }
